{
  "name": "cs440-health-app",
  "version": "0.1.0",
  "private": true,
  "description": "Local microservices health app with a user management service, health stats service, BFF, and API Gateway.",
  "main": "api-gateway/server.js",
  "scripts": {
    "dev": "npm run dev:gateway",
    "dev:gateway": "PORT=3000 BFF_URL=http://localhost:3100 USER_SERVICE_URL=http://localhost:3101 HEALTH_STATS_SERVICE_URL=http://localhost:3102 node --watch api-gateway/server.js",
    "dev:bff": "PORT=3100 USER_SERVICE_URL=http://localhost:3101 HEALTH_STATS_SERVICE_URL=http://localhost:3102 SQLITE_PATH=data/bff.sqlite node --watch services/bff/server.js",
    "dev:user-management": "PORT=3101 SQLITE_PATH=data/user-management.sqlite node --watch services/user-management/server.js",
    "dev:health-stats": "PORT=3102 SQLITE_PATH=data/health-stats.sqlite node --watch services/health-stats/server.js",
    "start": "npm run start:gateway",
    "start:gateway": "PORT=3000 node api-gateway/server.js",
    "start:bff": "PORT=3100 node services/bff/server.js",
    "start:user-management": "PORT=3101 node services/user-management/server.js",
    "start:health-stats": "PORT=3102 node services/health-stats/server.js",
    "lint": "eslint .",
    "build": "node -e \"console.log('Build check complete')\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.1",
    "globals": "^15.15.0"
  }
}
